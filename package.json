{
  "name": "todo-list-api",
  "version": "1.0.0",
  "description": "API REST para plataforma de tarefas (To-do) - Projeto C2",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "tsx src/server.ts",
